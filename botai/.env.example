# ─── Centurion CUTM AI Chatbot — Environment Secrets Template ────────────────
# Copy this file to '.env' and fill in your actual production credentials.
# DO NOT commit the actual '.env' containing real secrets to Git/GitHub!

# MySQL connection settings
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=cutm_ai

# Anthropic Claude API keys (comma-separated list for round-robin load-balancing)
# Both variable names (CLAUDE_API_KEY and CLAUDE_API_KEYS) are fully supported and parsed by the rotator.
CLAUDE_API_KEYS=sk-ant-api03-YOUR_KEY_1,sk-ant-api03-YOUR_KEY_2,sk-ant-api03-YOUR_KEY_3,sk-ant-api03-YOUR_KEY_4

# Google OAuth 2.0 Client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# Admin initial credentials (used by database_setup.py seeding)
ADMIN_PASSWORD=admin123

# --- Email Notifications (Gmail SMTP) ----------------------------------------
# The Gmail address that SENDS the notification emails
SMTP_EMAIL=your_sender@cutmap.ac.in
# Gmail App Password (NOT your regular password)
# Get it at: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your_app_password
# The admin email that RECEIVES all notifications
ADMIN_EMAIL=admin1@example.com, admin2@example.com

# User Daily Usage Reports & Alert settings
ENABLE_USER_USAGE_EMAILS=True
USER_DAILY_WARNING_THRESHOLD_USD=0.50

# Anthropic Credit Balance (set to your actual API account balance in USD)
# Used in daily monitoring emails for remaining credit calculations
ANTHROPIC_CREDIT_BALANCE=0.0

# --- API Key Security ---------------------------------------------------------
# Comma-separated list of IPs allowed to call API endpoints. Empty = allow all (dev mode).
# Example: API_IP_WHITELIST=127.0.0.1,203.0.113.50,198.51.100.0/24
API_IP_WHITELIST=

# HMAC signing secret: requests must include X-Signature header computed as HMAC-SHA256(body, API_SIGNING_SECRET)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_SIGNING_SECRET=
REQUIRE_REQUEST_SIGNING=False

# Anomaly detection limits
MAX_TOKENS_PER_USER_PER_HOUR=500000
MAX_API_CALLS_PER_USER_PER_MIN=20

