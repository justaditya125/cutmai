# ─── Centurion CUTM AI Chatbot — Environment Secrets Template ────────────────
# Copy this file to '.env' and fill in your actual production credentials.
# DO NOT commit the actual '.env' containing real secrets to Git/GitHub!

# MongoDB connection string (local or Atlas)
MONGO_URI=mongodb://localhost:27017/cutm_ai

# Anthropic Claude API keys (comma-separated list for round-robin load-balancing)
# Both variable names (CLAUDE_API_KEY and CLAUDE_API_KEYS) are fully supported and parsed by the rotator.
CLAUDE_API_KEYS=sk-ant-api03-YOUR_KEY_1,sk-ant-api03-YOUR_KEY_2,sk-ant-api03-YOUR_KEY_3,sk-ant-api03-YOUR_KEY_4

# Google OAuth 2.0 Client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# Admin initial credentials (used by database_setup.py seeding)
ADMIN_PASSWORD=admin123
